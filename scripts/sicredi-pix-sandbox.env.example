# Copie para sicredi-pix-sandbox.env e preencha. Este arquivo (*.env) é gitignored.
# O Pix do Sicredi EXIGE certificado mTLS (.cer PEM + .key sem senha).

export SICREDI_BASE="https://api-pix.sicredi.com.br"   # homologação: solicite a URL ao Sicredi
export CLIENT_ID=""
export CLIENT_SECRET=""
export CHAVE_PIX=""                                    # chave Pix do recebedor
export CERT="/caminho/absoluto/certificado.cer"        # PEM
export KEY="/caminho/absoluto/chave.key"               # sem senha
