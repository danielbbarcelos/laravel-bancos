# =============================================================================
# laravel-bancos — variáveis de ambiente
# =============================================================================
# Copie o que for usar para o .env do seu APP. Em SaaS/multi-tenant você pode
# deixar as credenciais em branco aqui e passá-las em runtime via
# Bancos::build('sicredi', [...]) — veja o README (seção "Uso em SaaS").
# =============================================================================

# Banco padrão usado por Bancos::pix() / Bancos::boleto() sem especificar driver.
BANCO_DRIVER=sicredi


# -----------------------------------------------------------------------------
# SICREDI — Pix (API Pix BACEN)
# -----------------------------------------------------------------------------
SICREDI_CLIENT_ID=
SICREDI_CLIENT_SECRET=
SICREDI_CHAVE_PIX=

# Certificado mTLS — OBRIGATÓRIO em produção (sem ele toda chamada Pix volta 403).
# Baixe no Portal do Desenvolvedor: .cer (PEM) + a chave .key SEM senha.
SICREDI_CERT_PATH=/caminho/absoluto/certificado.cer
SICREDI_KEY_PATH=/caminho/absoluto/chave.key
# SICREDI_CERT_PASSWORD=

# Scopes OAuth2 — obrigatórios. Vazio usa o default do driver (cob + cobv + pix + webhook).
# SICREDI_SCOPES="cob.read cob.write cobv.read cobv.write pix.read pix.write webhook.read webhook.write"

# Produção (default): https://api-pix.sicredi.com.br
# Homologação: URL não é pública — solicite ao Sicredi (integracoes_pix@sicredi.com.br).
SICREDI_BASE_URL=https://api-pix.sicredi.com.br

SICREDI_TIMEOUT=30

# Retry com backoff (transitórios: timeout/conexão e 5xx; 4xx não re-tenta).
SICREDI_TENTATIVAS=3
SICREDI_RETRY_INTERVALO_MS=200

# Segurança: base_url DEVE ser https. Deixe false (só libere http em DEV local).
SICREDI_PERMITIR_HTTP=false
# Máx. de Pix por notificação de webhook (anti-DoS).
SICREDI_WEBHOOK_MAX_ITENS=1000


# -----------------------------------------------------------------------------
# SICREDI — Boleto (API de Cobrança) — produto SEPARADO do Pix
# -----------------------------------------------------------------------------
# OAuth2 grant_type=password + x-api-key (SEM mTLS). Credenciais vêm do Portal
# do Desenvolvedor + código de acesso gerado no Internet Banking.
SICREDI_BOLETO_API_KEY=
SICREDI_BOLETO_USERNAME=          # beneficiário + código da cooperativa
SICREDI_BOLETO_ACCESS_CODE=       # código de acesso (Internet Banking)
SICREDI_BOLETO_COOPERATIVA=
SICREDI_BOLETO_POSTO=
SICREDI_BOLETO_COD_BENEFICIARIO=

# Produção: https://api-parceiro.sicredi.com.br
# Homologação (sandbox): https://api-parceiro.sicredi.com.br/sb
SICREDI_BOLETO_BASE_URL=https://api-parceiro.sicredi.com.br


# -----------------------------------------------------------------------------
# C6 BANK — Pix  (⚠️ NÃO FINALIZADO: auth/rotas a confirmar na doc oficial)
# -----------------------------------------------------------------------------
C6_CLIENT_ID=
C6_CLIENT_SECRET=
C6_CHAVE_PIX=
C6_CERT_PATH=
C6_KEY_PATH=
C6_BASE_URL=https://baas-api-pix.c6bank.info
C6_TIMEOUT=30

# Pontos a confirmar no portal do C6 (developers.c6bank.com.br — exige cadastro):
# C6_TOKEN_URL=/v1/auth/oauth/token
# C6_TOKEN_VIA_BASIC=true
# C6_SCOPES="cob.write cob.read pix.write pix.read"
# C6_ROTA_COB=/v2/cob
# C6_ROTA_PIX=/v2/pix
