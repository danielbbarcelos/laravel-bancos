{
    "name": "danielbbarcelos/laravel-bancos",
    "description": "Integração com bancos brasileiros (Pix, boleto, pagamentos, conciliação) sob um contrato único, com drivers por banco.",
    "keywords": ["laravel", "pix", "boleto", "bancos", "pagamentos", "sicredi", "c6", "bacen"],
    "license": "MIT",
    "authors": [
        {
            "name": "Daniel Barcelos",
            "email": "daniel@danielbarcelos.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "DanielBBarcelos\\Bancos\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DanielBBarcelos\\Bancos\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DanielBBarcelos\\Bancos\\BancosServiceProvider"
            ],
            "aliases": {
                "Bancos": "DanielBBarcelos\\Bancos\\Facades\\Bancos"
            }
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
